<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="Ke_titMKDQ81SpA_TZuD">
    <mxGraphModel dx="1717" dy="890" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam packageStyle rectangle\n\npackage \&quot;Domain\&quot; {\n    class User {\n        - UUID: String\n        - username: String\n        - password: String\n        + getUUID(): String\n        + getUsername(): String\n        + getPassword(): String\n    }\n\n    class Task {\n        - UUID: String\n        - title: String\n        - description: String\n        - priority: TaskPriority\n        - timeLabel: TaskTimeLabel\n        + getUUID(): String\n        + getTitle(): String\n        + getDescription(): String\n        + getPriority(): String\n        + getTimeLabel(): String\n    }\n\n    enum TaskPriority {\n        Low\n        Medium\n        High\n    }\n\n    enum TaskTimeLabel {\n        Daily\n        Monthly\n        Yearly\n    }\n\n    Task \&quot;1\&quot; *-- \&quot;1\&quot; TaskPriority : has\n    Task \&quot;1\&quot; *-- \&quot;1\&quot; TaskTimeLabel : has\n    User \&quot;1\&quot; --&gt; \&quot;0..n\&quot; Task : manages\n}\n\npackage \&quot;Repositories\&quot; {\n    class UserRepo &lt;&lt;boundary&gt;&gt; {\n        + UserRepo()\n        + findBy(username: String, password: String): User\n    }\n\n    class TaskRepo &lt;&lt;boundary&gt;&gt; {\n        + TaskRepo()\n        + saveTask(task: Task): void\n    }\n    \n    UserRepo ..&gt; User : returneaza\n    TaskRepo ..&gt; Task : salveaza/cauta\n}\n\npackage \&quot;Services\&quot; {\n    class TaskService &lt;&lt;control&gt;&gt; {\n        - taskRepo: TaskRepo\n        + TaskService(tr: TaskRepo)\n        + createTask(titlu: String, desc: String, prio: String, timp: String): void\n    }\n    \n    TaskService o--&gt; TaskRepo : injectat prin constructor\n}\n\npackage \&quot;Controllers\&quot; {\n    class LoginController &lt;&lt;control&gt;&gt; {\n        - userRepo: UserRepo\n        + LoginController(ur: UserRepo)\n        + handleLogin(username: String, password: String): User\n    }\n\n    class MainController &lt;&lt;boundary&gt;&gt; {\n        - taskService: TaskService\n        - currentUser: User\n        + MainController(ts: TaskService, user: User)\n        + clickAdd(): void\n        + refreshTaskList(): void\n    }\n    \n    LoginController o--&gt; UserRepo : injectat prin constructor\n    MainController o--&gt; TaskService : injectat prin constructor\n    MainController --&gt; User : stocheaza user-ul curent\n}\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="XPaAUYpu1IVjzqhScV6F-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1241" width="1092" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
