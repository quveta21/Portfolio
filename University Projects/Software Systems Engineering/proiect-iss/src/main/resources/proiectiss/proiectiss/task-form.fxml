<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Creare Task Nou">
        <font>
            <Font name="System Bold" size="18.0"/>
        </font>
    </Label>

    <GridPane hgap="10" vgap="15">
        <Label text="Titlu:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="titleField" promptText="Ex: Proiect Java" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Descriere:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextArea fx:id="descField" prefRowCount="3" promptText="Detalii task..." GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Prioritate:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="priorityCombo" promptText="Alege..." GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Interval Timp:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ComboBox fx:id="timeCombo" promptText="Alege..." GridPane.columnIndex="1" GridPane.rowIndex="3"/>
    </GridPane>

    <Label fx:id="errorLabel" textFill="RED"/>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Anuleaza" onAction="#onCancelClick" style="-fx-background-color: #9e9e9e; -fx-text-fill: white;"/>
        <Button text="Salveaza" onAction="#onSaveClick" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
    </HBox>
</VBox>