    15 00000016 7403                            jz diferit_de_1
    16 00000018 83C301                          add EBX, 1 ; daca e 1, incrementam EBX iar rezultatul final e in EBX
    17                                          
    18                                          diferit_de_1:
    19 0000001B D1E8                            shr EAX, 1 ; trecem la cifra urmatoare
    20 0000001D 83F800                          cmp EAX, 0
    21                                          
    22 00000020 75EC                            jnz repeta
    23                                          
