    33 00000009 68[00000000]                    push dword s1 ; ESP + 8
    34 0000000E 68[17000000]                    push dword p1 ; ESP + 4
    35 00000013 E8(00000000)                    call prefix ; gaseste prefixul comun pt s1 s2
    36                                          
    37 00000018 6A07                            push dword l3
    38 0000001A 68[0F000000]                    push dword s3
    39 0000001F 6A06                            push dword l2
