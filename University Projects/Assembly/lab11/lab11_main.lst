    52 0000004D 68[08000000]                    push dword s2
    53 00000052 68[00000000]                    push dword s1
    54 00000057 68[42000000]                    push dword format
    55 0000005C FF15[00000000]                  call [printf] ; afiseaza prefixul pt s1 s2
    56 00000062 83C410                          add ESP, 4*4
    57                                          
    58 00000065 68[25000000]                    push dword p2
