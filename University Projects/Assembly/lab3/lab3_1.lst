     1                                  bits 32 ; assembling for the 32 bits architecture
     2                                  
     3                                  ; declare the EntryPoint (a label defining the very first instruction of the program)
     4                                  global start        
     5                                  
     6                                  ; declare external functions needed by our program
     7                                  extern exit               ; tell nasm that exit exists even if we won't be defining it
     8                                  import exit msvcrt.dll    ; exit is a function that ends the calling process. It is defined in msvcrt.dll
     9                                                            ; msvcrt.dll contains exit, printf and all the other important C-runtime specific functions
    10                                  
    11                                  ; our data is declared here (the variables needed by our program)
    12                                  segment data use32 class=data
    13                                      ; ...
    14 00000000 0A                          a db 10
    15 00000001 0700                        b dw 7
    16 00000003 32000000                    c dd 50
    17 00000007 0F00000000000000            d dq 15
    18                                  
    19                                  ; our code starts here
    20                                  segment code use32 class=code
    21                                      start:
    22                                          ; ...
    23                                          ;c-(d+d+d)+(a-b)
    24 00000000 BA00000000                      mov EDX, 0
    25 00000005 A1[03000000]                    mov EAX, [c] ; c - qword
    26 0000000A 2B05[07000000]                  sub EAX, [d]
    27 00000010 1B15[0B000000]                  sbb EDX, [d+4]
    28 00000016 2B05[07000000]                  sub EAX, [d]
    29 0000001C 1B15[0B000000]                  sbb EDX, [d+4]
    30 00000022 2B05[07000000]                  sub EAX, [d]
    31 00000028 1B15[0B000000]                  sbb EDX, [d+4] ; c - (d+d+d)
    32 0000002E BB00000000                      mov EBX, 0
    33 00000033 8A1D[00000000]                  mov BL, [a] ; a -> word
    34 00000039 662B1D[01000000]                sub BX, [b] ; (a-b)
    35 00000040 B900000000                      mov ECX, 0
    36 00000045 01D8                            add EAX, EBX
    37 00000047 11CA                            adc EDX, ECX ; c-(d+d+d)+(a-b)
    38                                      
    39                                          ; exit(0)
    40 00000049 6A00                            push    dword 0      ; push the parameter for exit onto the stack
    41 0000004B FF15[00000000]                  call    [exit]       ; call exit to terminate the program
