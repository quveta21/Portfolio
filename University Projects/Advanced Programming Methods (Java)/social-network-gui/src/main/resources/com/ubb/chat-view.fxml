<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="500.0" minWidth="700.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">

    <top>
        <VBox style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <padding>
                        <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                    </padding>
                    <children>
                        <Label text="Duck Chat" textFill="#f1c40f">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>

                        <Region HBox.hgrow="ALWAYS" />

                        <VBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label fx:id="currentUserLabel" text="Current user: Guest" textFill="#bdc3c7">
                                    <font>
                                        <Font name="System Italic" size="12.0" />
                                    </font>
                                </Label>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Button fx:id="btnLogin" mnemonicParsing="false" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5;" text="Login">
                                            <font>
                                                <Font name="System Bold" size="11.0" />
                                            </font>
                                        </Button>
                                        <Button fx:id="btnLogout" mnemonicParsing="false" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5;" text="Logout">
                                            <font>
                                                <Font name="System Bold" size="11.0" />
                                            </font>
                                        </Button>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Button fx:id="btnNotifications" mnemonicParsing="false" style="-fx-background-color: #f1c40f; -fx-text-fill: #2c3e50; -fx-cursor: hand; -fx-background-radius: 5;" text="Notifications: 0">
                                            <font>
                                                <Font name="System Bold" size="11.0" />
                                            </font>
                                            <padding>
                                                <Insets bottom="8.0" left="30.0" right="30.0" top="8.0" />
                                            </padding>
                                        </Button>
                                    </children>
                                    <VBox.margin>
                                        <Insets top="5.0" />
                                    </VBox.margin>
                                </HBox>
                            </children>
                        </VBox>

                        <Label fx:id="typingLabel" text="" textFill="#f1c40f">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>

                        <Region HBox.hgrow="ALWAYS" />

                        <VBox alignment="CENTER_RIGHT">
                            <children>
                                <Label text="Chat with:" textFill="WHITE">
                                    <font>
                                        <Font size="12.0" />
                                    </font>
                                </Label>
                                <ComboBox fx:id="comboUserSelector" prefWidth="180.0" promptText="Select a user..." style="-fx-background-color: white; -fx-background-radius: 5;" />
                                <HBox alignment="CENTER">
                                    <children>
                                        <Button fx:id="btnAddFriend" mnemonicParsing="false" style="-fx-background-color: #f1c40f; -fx-text-fill: #2c3e50; -fx-cursor: hand; -fx-background-radius: 5;" text="Select a user first!">
                                            <font>
                                                <Font name="System Bold" size="11.0" />
                                            </font>
                                            <padding>
                                                <Insets bottom="8.0" left="30.0" right="30.0" top="8.0" />
                                            </padding>
                                        </Button>
                                    </children>
                                    <VBox.margin>
                                        <Insets top="5.0" />
                                    </VBox.margin>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f4f4f4;" BorderPane.alignment="CENTER">
            <content>
                <VBox fx:id="messagesContainer" spacing="10.0" style="-fx-background-color: #f4f4f4;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <VBox style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER">
            <children>

                <HBox fx:id="replyPreviewPanel" alignment="CENTER_LEFT" managed="false" spacing="10.0" style="-fx-background-color: #dfe6e9; -fx-border-color: #b2bec3; -fx-border-width: 0 0 1 0;" visible="false">
                    <padding>
                        <Insets bottom="5.0" left="15.0" right="15.0" top="5.0" />
                    </padding>
                    <children>
                        <VBox>
                            <children>
                                <Label text="Replying to:" textFill="#7f8c8d">
                                    <font>
                                        <Font name="System Italic" size="10.0" />
                                    </font>
                                </Label>
                                <Label fx:id="replyPreviewLabel" text="User X: Hello there..." textFill="#2d3436">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnCancelReply" mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand;" text="✕" textFill="#c0392b">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>

                <HBox alignment="CENTER" spacing="10.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <TextArea fx:id="messageInput" prefHeight="40.0" prefRowCount="1" promptText="Type a message..." style="-fx-background-radius: 5;" wrapText="true" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnSend" minHeight="40.0" minWidth="60.0" mnemonicParsing="false" style="-fx-background-color: #f1c40f; -fx-text-fill: #2c3e50; -fx-background-radius: 5; -fx-cursor: hand;" text="SEND">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </bottom>

</BorderPane>